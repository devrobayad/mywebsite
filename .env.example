# Environment variables required for devrobayad-portfolio

# PORT: The port the backend will run on inside the sandbox.
# Always hardcoded to 3000 by the infrastructure.
PORT=3000

# APP_URL: The URL where this applet is hosted (e.g., in the preview)
APP_URL="MY_APP_URL"

# Database Configuration (Optional fallback exists to local file DB)
MONGO_URI="mongodb://localhost:27017/devrobayad"

# JWT Secret for Admin Panel Authentication
JWT_SECRET="super-secret-devrobayad-jwt-key-2025"

# Admin Credentials (for seed.js and fallback login)
ADMIN_USERNAME="robayad"
ADMIN_PASSWORD="secure_password_132"

# Email Notifications Settings (nodemailer)
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password"

# Public site URL
SITE_URL="https://devrobayad.com"
